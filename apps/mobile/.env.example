# Required. Backend API base URL. Production builds MUST set this via EAS
# env/secrets — the value here is only a convenience for local development.
EXPO_PUBLIC_API_URL=https://nlp-training-backend-production.up.railway.app

# Required. Clerk publishable key. Use a pk_live_... key for production builds.
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_replace_me

# Optional. Override the web hosts used for sign-up / privacy / terms links and
# the upgrade/checkout flow. Defaults are the production sovereignty domains.
EXPO_PUBLIC_WEB_URL=https://heart.sovereignty.app
EXPO_PUBLIC_PURCHASE_URL=https://start.sovereignty.app
